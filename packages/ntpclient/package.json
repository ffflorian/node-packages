{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "bin": "dist/cli.js",
  "dependencies": {
    "commander": "15.0.0"
  },
  "description": "A TypeScript implementation of the NTP Client Protocol",
  "devDependencies": {
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">= 22.12.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "GPL-3.0",
  "module": "dist/index.js",
  "name": "ntpclient",
  "readme": "https://github.com/ffflorian/node-packages#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ffflorian/node-packages.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dist": "yarn clean && yarn build",
    "start": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "type": "module",
  "version": "1.16.3"
}
